# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Sensitive / user-specific files ──────────────────────────────────────────
# These are generated by bootstrap.py for YOUR Cloudflare account.
# Never commit them -- each user generates their own via:  python bootstrap.py

keys/                   # CF token (DPAPI), SSH key (DPAPI), portal_config.json
cf_config.txt           # saved HOME_USER, SSH_PORT, CF_HOST

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo

# ── Downloaded binaries & Go toolchain ───────────────────────────────────────
bin/cloudflared.exe
bin/tailscale.exe
bin/tailscaled.exe
bin/tailscale-ipn.exe
bin/wintun.dll
bin/lessmsi.exe
bin/tsnet.exe
bin/go-toolchain/

# ── tsnet state (Tailscale auth keys, persisted per-user) ────────────────────
keys/tsnet-state/

# ── Go build cache ────────────────────────────────────────────────────────────
tsnet-src/go.sum

# ── Tailscale MSI / installers ────────────────────────────────────────────────
*.msi
*.exe
*.tgz
*.zip
Archive.zip
lessmsi_out.txt
