# ── Generated at runtime (user-specific, never commit) ──────────────────────
keys/                   # CF tokens, config (portal_config.json), DPAPI secrets
cf_config.txt           # connect.bat/sh saved settings

# ── Environment / secrets ────────────────────────────────────────────────────
.env
.env.*

# ── Python cache ─────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo

# ── Downloaded binaries & Go toolchain ───────────────────────────────────────
bin/

# ── Go build artifacts ───────────────────────────────────────────────────────
tsnet/go.sum

# ── Downloaded archives ──────────────────────────────────────────────────────
*.msi
*.tgz
*.zip
