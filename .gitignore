# ── User-specific runtime files ──────────────────────────────────────────────
# Generated by bootstrap.py for YOUR Cloudflare account.
# Never commit -- each user generates their own via:  python bootstrap.py

keys/                   # tokens, config, DPAPI secrets, generated installers
cf_config.txt           # saved HOME_USER, SSH_PORT, CF_HOST

# ── Environment / secrets ────────────────────────────────────────────────────
.env
.env.*

# ── Python cache ─────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo

# ── Downloaded binaries & Go toolchain ───────────────────────────────────────
bin/

# ── Go build artifacts ───────────────────────────────────────────────────────
tsnet/go.sum

# ── Downloaded archives / installers ─────────────────────────────────────────
*.msi
*.tgz
*.zip
